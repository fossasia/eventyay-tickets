#: pretix/base/models/event.py:1590
msgid "One or more variations do not belong to this event."
msgstr "Один або декілька варіантів не належать до цієї події."

#: pretix/base/models/event.py:1683 pretix/base/models/items.py:1523
msgid "Can not contain spaces or special characters except underscores"
msgstr ""
"Не може містити пробіли або спеціальні символи, окрім символів підкреслення"

#: pretix/base/models/event.py:1688 pretix/base/models/items.py:1528
msgid "The property name may only contain letters, numbers and underscores."
msgstr ""
"Назва властивості може містити лише літери, цифри та символи підкреслення."

#: pretix/base/models/event.py:1694
msgid "Default value"
msgstr "Значення за замовчуванням"

#: pretix/base/models/event.py:1697
msgid "Can only be changed by organizer-level administrators"
msgstr "Можуть змінити лише адміністратори рівня організатора"

#: pretix/base/models/event.py:1701
msgid "Required for events"
msgstr "Обов'язково для подій"

#: pretix/base/models/event.py:1703
msgid ""
"If checked, an event can only be taken live if the property is set. In event "
"series, its always optional to set a value for individual dates"
msgstr ""
"Якщо позначено, подію можна опублікувати, лише якщо властивість встановлено. "
"У серії подій завжди необов'язково встановлювати значення для окремих дат"

#: pretix/base/models/event.py:1710
msgid "Valid values"
msgstr "Дійсні значення"

#: pretix/base/models/event.py:1712
msgid ""
"If you keep this empty, any value is allowed. Otherwise, enter one possible "
"value per line."
msgstr ""
"Якщо залишити це поле порожнім, дозволено будь-яке значення. В іншому "
"випадку вводьте одне можливе значення в кожному рядку."

#: pretix/base/models/event.py:1721
msgid "A property can either be required or have a default value, not both."
msgstr ""
"Властивість може бути або обов'язковою, або мати значення за замовчуванням, "
"але не одночасно."

#: pretix/base/models/event.py:1730
msgid "You cannot set a default value that is not a valid value."
msgstr ""
"Не можна встановити значення за замовчуванням, яке не є дійсним значенням."

#: pretix/base/models/fields.py:12
msgid "No value can contain the delimiter character."
msgstr "Жодне значення не може містити символ роздільника."

#: pretix/base/models/giftcards.py:58
msgid "The gift card code may only contain letters, numbers, dots and dashes."
msgstr ""
"Код подарункової картки може містити лише літери, цифри, крапки та тире."

#: pretix/base/models/giftcards.py:70
#: pretix/control/templates/pretixcontrol/organizers/giftcard.html:39
msgctxt "giftcard"
msgid "Special terms and conditions"
msgstr "Спеціальні умови та положення"

#: pretix/base/models/invoices.py:129
#, python-format
msgctxt "invoice"
msgid "Tax ID: %s"
msgstr "Податковий ідентифікатор: %s"

#: pretix/base/models/invoices.py:135 pretix/base/services/invoices.py:103
#, python-format
msgctxt "invoice"
msgid "VAT-ID: %s"
msgstr "VAT-ID: %s"

#: pretix/base/models/items.py:51
msgid "Category name"
msgstr "Назва категорії"

#: pretix/base/models/items.py:54 pretix/base/models/items.py:271
msgid "Internal name"
msgstr "Внутрішнє ім'я"

#: pretix/base/models/items.py:55 pretix/base/models/items.py:272
msgid ""
"If you set this, this will be used instead of the public name in the backend."
msgstr ""
"Якщо ви встановите це значення, воно буде використовуватися замість "
"публічного імені в бекенді."

#: pretix/base/models/items.py:59
msgid "Category description"
msgstr "Опис категорії"

#: pretix/base/models/items.py:66
msgid "Products in this category are add-on products"
msgstr "Продукти цієї категорії є додатковими продуктами"

#: pretix/base/models/items.py:67
msgid ""
"If selected, the products belonging to this category are not for sale on "
"their own. They can only be bought in combination with a product that has "
"this category configured as a possible source for add-ons."
msgstr ""
"Якщо вибрано, товари, що належать до цієї категорії, не продаються окремо. "
"Їх можна придбати лише в поєднанні з товаром, для якого ця категорія "
"налаштована як можливе джерело доповнень."

#: pretix/base/models/items.py:73 pretix/base/pdf.py:99
#: pretix/control/templates/pretixcontrol/items/category.html:4
#: pretix/control/templates/pretixcontrol/items/category.html:9
msgid "Product category"
msgstr "Категорія продукту"

#: pretix/base/models/items.py:74
#: pretix/control/templates/pretixcontrol/items/categories.html:3
#: pretix/control/templates/pretixcontrol/items/categories.html:8
#: pretix/control/templates/pretixcontrol/items/categories.html:38
msgid "Product categories"
msgstr "Категорії товарів"

#: pretix/base/models/items.py:80
#, python-brace-format
msgid "{category} (Add-On products)"
msgstr "{category} (Додаткові продукти)"

#: pretix/base/models/items.py:123
msgid "Disable product for this date"
msgstr "Вимкнути продукт на цю дату"

#: pretix/base/models/items.py:263 pretix/base/models/items.py:829
#: pretix/control/templates/pretixcontrol/items/index.html:45
msgid "Category"
msgstr "Категорія"

#: pretix/base/models/items.py:264
msgid ""
"If you have many products, you can optionally sort them into categories to "
"keep things organized."
msgstr ""
"Якщо у вас багато товарів, ви можете за бажанням сортувати їх за категоріями "
"для більшої організації."

#: pretix/base/models/items.py:268
msgid "Item name"
msgstr "Назва елемента"

#: pretix/base/models/items.py:281
msgid "This is shown below the product name in lists."
msgstr "Це відображається під назвою продукту у списках."

#: pretix/base/models/items.py:285 pretix/base/models/items.py:663
msgid "Default price"
msgstr "Ціна за замовчуванням"

#: pretix/base/models/items.py:286
msgid ""
"If this product has multiple variations, you can set different prices for "
"each of the variations. If a variation does not have a special price or if "
"you do not have variations, this price will be used."
msgstr ""
"Якщо цей товар має кілька варіацій, ви можете встановити різні ціни для "
"кожної з них. Якщо для варіації немає спеціальної ціни або якщо у вас немає "
"варіацій, буде використано цю ціну."

#: pretix/base/models/items.py:293
msgid "Free price input"
msgstr "Безкоштовне введення ціни"

#: pretix/base/models/items.py:294
msgid ""
"If this option is active, your users can choose the price themselves. The "
"price configured above is then interpreted as the minimum price a user has "
"to enter. You could use this e.g. to collect additional donations for your "
"event. This is currently not supported for products that are bought as an "
"add-on to other products."
msgstr ""
"Якщо ця опція активна, ваші користувачі можуть самі вибирати ціну. Ціна, "
"налаштована вище, потім інтерпретується як мінімальна ціна, яку користувач "
"повинен ввести. Ви можете використовувати це, наприклад, для збору "
"додаткових пожертвувань для вашого заходу. Наразі це не підтримується для "
"продуктів, які купуються як доповнення до інших продуктів."

#: pretix/base/models/items.py:301
msgid "Sales tax"
msgstr "Податок з продажу"

#: pretix/base/models/items.py:306
msgid "Is an admission ticket"
msgstr "Є вхідним квитком"

#: pretix/base/models/items.py:308
msgid "Whether or not buying this product allows a person to enter your event"
msgstr "Чи дозволяє купівля цього продукту людині потрапити на ваш захід"

#: pretix/base/models/items.py:314
msgid "Generate tickets"
msgstr "Згенерувати квитки"

#: pretix/base/models/items.py:318
msgid "Show a waiting list for this ticket"
msgstr "Показати список очікування на цей квиток"

#: pretix/base/models/items.py:319
msgid "This will only work if waiting lists are enabled for this event."
msgstr ""
"Це працюватиме лише за умови, що для цієї події ввімкнено списки очікування."

#: pretix/base/models/items.py:324
msgid "Publicly show how many tickets are still available."
msgstr "Публічно покажіть, скільки квитків ще доступно."

#: pretix/base/models/items.py:331
msgid "Product picture"
msgstr "Зображення продукту"

#: pretix/base/models/items.py:336
msgid "Available from"
msgstr "Доступно з"

#: pretix/base/models/items.py:338
msgid "This product will not be sold before the given date."
msgstr "Цей товар не буде проданий раніше зазначеної дати."

#: pretix/base/models/items.py:341 pretix/base/payment.py:249
msgid "Available until"
msgstr "Доступно до"

#: pretix/base/models/items.py:343
msgid "This product will not be sold after the given date."
msgstr "Цей товар не продаватиметься після зазначеної дати."

#: pretix/base/models/items.py:349
msgid "Only show after sellout of"
msgstr "Показувати лише після розпродажу"

#: pretix/base/models/items.py:350
msgid ""
"If you select a quota here, this product will only be shown when that quota "
"is unavailable. If combined with the option to hide sold-out products, this "
"allows you to swap out products for more expensive ones once they are sold "
"out. There might be a short period in which both products are visible while "
"all tickets in the referenced quota are reserved, but not yet sold."
msgstr ""
"Якщо ви оберете тут квоту, цей продукт відображатиметься лише тоді, коли ця "
"квота недоступна. У поєднанні з опцією приховування розпроданих продуктів це "
"дозволить вам обміняти продукти на дорожчі, коли вони розпродані. Може бути "
"короткий період, протягом якого обидва продукти будуть видимими, тоді як усі "
"квитки в межах зазначеної квоти зарезервовані, але ще не продані."

#: pretix/base/models/items.py:357
msgid "This product can only be bought using a voucher."
msgstr "Цей товар можна придбати лише за допомогою ваучера."

#: pretix/base/models/items.py:359
msgid ""
"To buy this product, the user needs a voucher that applies to this product "
"either directly or via a quota."
msgstr ""
"Щоб придбати цей товар, користувачеві потрібен ваучер, який застосовується "
"до цього товару безпосередньо або через квоту."

#: pretix/base/models/items.py:363
msgid "Buying this product requires approval"
msgstr "Купівля цього товару вимагає схвалення"

#: pretix/base/models/items.py:365
msgid ""
"If this product is part of an order, the order will be put into an "
"\"approval\" state and will need to be confirmed by you before it can be "
"paid and completed. You can use this e.g. for discounted tickets that are "
"only available to specific groups."
msgstr ""
"Якщо цей товар є частиною замовлення, замовлення буде переведено у стан "
"«схвалення» та потребуватиме вашого підтвердження, перш ніж його можна буде "
"оплатити та завершити. Ви можете використовувати це, наприклад, для квитків "
"зі знижкою, доступних лише для певних груп."

#: pretix/base/models/items.py:370
msgid ""
"This product will only be shown if a voucher matching the product is "
"redeemed."
msgstr ""
"Цей продукт буде показано лише за умови використання ваучера, що відповідає "
"продукту."

#: pretix/base/models/items.py:372
msgid ""
"This product will be hidden from the event page until the user enters a "
"voucher that unlocks this product."
msgstr ""
"Цей продукт буде прихований на сторінці події, доки користувач не введе "
"ваучер, який розблокує цей продукт."

#: pretix/base/models/items.py:376
msgid "Only sell this product as part of a bundle"
msgstr "Продавайте цей товар лише як частину комплекту"

#: pretix/base/models/items.py:378
msgid ""
"If this option is set, the product will only be sold as part of bundle "
"products. Do <strong>not</strong> check this option if you want to use this "
"product as an add-on product, but only for fixed bundles!"
msgstr ""
"Якщо цю опцію встановлено, продукт продаватиметься лише у складі наборів. "
"<strong>не</strong> встановлюйте цю опцію, якщо ви хочете використовувати "
"цей продукт як додатковий продукт, а лише для фіксованих наборів!"

#: pretix/base/models/items.py:383
msgid "Allow product to be canceled or changed"
msgstr "Дозволити скасування або зміну товару"

#: pretix/base/models/items.py:385
msgid ""
"If this is checked, the usual cancellation and order change settings of this "
"event apply. If this is unchecked, orders containing this product can not be "
"canceled by users but only by you."
msgstr ""
"Якщо цей прапорець позначено, застосовуються звичайні налаштування "
"скасування та зміни замовлення для цієї події. Якщо цей прапорець знято, "
"замовлення, що містять цей товар, не можуть бути скасовані користувачами, а "
"лише вами."

#: pretix/base/models/items.py:389
msgid "Minimum amount per order"
msgstr "Мінімальна сума на замовлення"

#: pretix/base/models/items.py:391
msgid ""
"This product can only be bought if it is added to the cart at least this "
"many times. If you keep the field empty or set it to 0, there is no special "
"limit for this product."
msgstr ""
"Цей товар можна купити, лише якщо його додавати до кошика щонайменше стільки "
"разів. Якщо залишити поле порожнім або встановити його значення 0, для цього "
"товару немає спеціального обмеження."

#: pretix/base/models/items.py:395
msgid "Maximum amount per order"
msgstr "Максимальна сума за замовлення"

#: pretix/base/models/items.py:397
msgid ""
"This product can only be bought at most this many times within one order. If "
"you keep the field empty or set it to 0, there is no special limit for this "
"product. The limit for the maximum number of items in the whole order "
"applies regardless."
msgstr ""
"Цей товар можна придбати лише певну кількість разів в одному замовленні. "
"Якщо залишити поле порожнім або встановити його значення 0, для цього товару "
"немає спеціального обмеження. Обмеження на максимальну кількість товарів у "
"всьому замовленні застосовується незалежно від цього."

#: pretix/base/models/items.py:404
msgid ""
"If you set this, the check-in app will show a visible warning that this "
"ticket requires special attention. You can use this for example for student "
"tickets to indicate to the person at check-in that the student ID card still "
"needs to be checked."
msgstr ""
"Якщо ви налаштуєте це, додаток для реєстрації відображатиме візуальне "
"попередження про те, що цей квиток потребує особливої уваги. Ви можете "
"використовувати це, наприклад, для студентських квитків, щоб повідомити "
"особі під час реєстрації, що студентський квиток все ще потрібно перевірити."

#: pretix/base/models/items.py:409 pretix/base/models/items.py:666
msgid "Original price"
msgstr "Початкова ціна"

#: pretix/base/models/items.py:412 pretix/base/models/items.py:669
msgid ""
"If set, this will be displayed next to the current price to show that the "
"current price is a discounted one. This is just a cosmetic setting and will "
"not actually impact pricing."
msgstr ""
"Якщо це налаштовано, це налаштування відображатиметься поруч із поточною "
"ціною, щоб показати, що поточна ціна зі знижкою. Це лише косметичне "
"налаштування, яке фактично не вплине на ціноутворення."

#: pretix/base/models/items.py:416 pretix/control/forms/event.py:932
#: pretix/control/forms/item.py:489
msgid "Sales channels"
msgstr "Канали збуту"

#: pretix/base/models/items.py:421
msgid "This product is a gift card"
msgstr "Цей продукт є подарунковою карткою"

#: pretix/base/models/items.py:422
msgid ""
"When a customer buys this product, they will get a gift card with a value "
"corresponding to the product price."
msgstr ""
"Коли покупець купує цей товар, він отримує подарункову карту номіналом, що "
"відповідає ціні товару."

#: pretix/base/models/items.py:431 pretix/base/models/items.py:1072
#: pretix/control/forms/filter.py:327 pretix/control/forms/filter.py:1199
#: pretix/control/forms/item.py:207 pretix/control/navigation.py:117
#: pretix/control/navigation.py:126
#: pretix/control/templates/pretixcontrol/checkin/lists.html:85
#: pretix/control/templates/pretixcontrol/items/base.html:3
#: pretix/control/templates/pretixcontrol/items/index.html:3
#: pretix/control/templates/pretixcontrol/items/index.html:8
#: pretix/control/templates/pretixcontrol/items/questions.html:35
#: pretix/control/templates/pretixcontrol/items/quotas.html:52
msgid "Products"
msgstr "Продукти"

#: pretix/base/models/items.py:590
msgid ""
"The maximum number per order can not be lower than the minimum number per "
"order."
msgstr ""
"Максимальна кількість на замовлення не може бути меншою за мінімальну "
"кількість на замовлення."

#: pretix/base/models/items.py:596
msgid "The item's category must belong to the same event as the item."
msgstr "Категорія елемента має належати до тієї ж події, що й сам елемент."

#: pretix/base/models/items.py:601
msgid "The item's tax rule must belong to the same event as the item."
msgstr ""
"Податкове правило для товару має належати до тієї ж події, що й сам товар."

#: pretix/base/models/items.py:607
msgid "The item's availability cannot end before it starts."
msgstr "Доступність товару не може закінчитися до його початку."

#: pretix/base/models/items.py:653
msgid "This is shown below the variation name in lists."
msgstr "Це відображається під назвою варіації у списках."

#: pretix/base/models/items.py:658 pretix/base/models/items.py:852
#: pretix/base/models/items.py:1078
msgid "Position"
msgstr "Позиція"

#: pretix/base/models/items.py:676 pretix/base/models/vouchers.py:163
#: pretix/base/models/waitinglist.py:75 pretix/base/orderimport.py:207
msgid "Product variation"
msgstr "Варіація продукту"

#: pretix/base/models/items.py:677
#: pretix/control/templates/pretixcontrol/item/create.html:63
msgid "Product variations"
msgstr "Варіації продукту"

#: pretix/base/models/items.py:834
msgid "Minimum number"
msgstr "Мінімальна кількість"

#: pretix/base/models/items.py:838
msgid "Maximum number"
msgstr "Максимальна кількість"

#: pretix/base/models/items.py:842
msgid "Add-Ons are included in the price"
msgstr "Додаткові опції включені у вартість"

#: pretix/base/models/items.py:843
msgid ""
"If selected, adding add-ons to this ticket is free, even if the add-ons "
"would normally cost money individually."
msgstr ""
"Якщо вибрано, додавання додаткових послуг до цього квитка буде безкоштовним, "
"навіть якщо зазвичай кожен додатковий сервіс окремо платний."

#: pretix/base/models/items.py:848
msgid "Allow the same product to be selected multiple times"
msgstr "Дозволити вибір одного й того ж продукту кілька разів"

#: pretix/base/models/items.py:867
msgid "The add-on's category must belong to the same event as the item."
msgstr "Категорія доповнення має належати до тієї ж події, що й елемент."

#: pretix/base/models/items.py:872
msgid "The item already has an add-on of this category."
msgstr "Цей товар вже має доповнення цієї категорії."

#: pretix/base/models/items.py:877
msgid "The minimum count needs to be equal to or greater than zero."
msgstr "Мінімальна кількість має бути рівною або більшою за нуль."

#: pretix/base/models/items.py:882
msgid "The maximum count needs to be equal to or greater than zero."
msgstr "Максимальна кількість має бути рівною або більшою за нуль."

#: pretix/base/models/items.py:887
msgid "The maximum count needs to be greater than the minimum count."
msgstr "Максимальна кількість має бути більшою за мінімальну кількість."

#: pretix/base/models/items.py:914
msgid "Bundled item"
msgstr "Комплектний товар"

