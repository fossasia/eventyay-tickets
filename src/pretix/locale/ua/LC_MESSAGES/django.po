#: pretix/control/forms/orders.py:434
msgid "inactive"
msgstr "неактивний"

#: pretix/control/forms/orderimport.py:9
msgid "Import mode"
msgstr "Режим імпорту"

#: pretix/control/forms/orderimport.py:11
msgid "Create a separate order for each line"
msgstr "Створіть окреме замовлення для кожного рядка"

#: pretix/control/forms/orderimport.py:12
msgid "Create one order with one position per line"
msgstr "Створіть одне замовлення з однією позицією на рядок"

#: pretix/control/forms/orderimport.py:18
msgid "Create orders as fully paid"
msgstr "Створити замовлення як повністю оплачені"

#: pretix/control/forms/orderimport.py:19
msgid "Create orders as pending and still require payment"
msgstr "Створити замовлення як очікують оплати, але все ще потрібно"

#: pretix/control/forms/orderimport.py:23
msgid "Create orders as test mode orders"
msgstr "Створювати замовлення як замовлення в тестовому режимі"

#: pretix/control/forms/orderimport.py:36
#, python-brace-format
msgid "CSV column: \"{name}\""
msgstr "Стовпець CSV: \"{name}\""

#: pretix/control/forms/orders.py:35
msgid "Overbook quota"
msgstr "Квота перебронювання"

#: pretix/control/forms/orders.py:36
msgid ""
"If you check this box, this operation will be performed even if it leads to "
"an overbooked quota and you having sold more tickets than you planned!"
msgstr ""
"Якщо ви поставите позначку в цьому полі, ця операція буде виконана, навіть "
"якщо це призведе до перебронювання квоти, і ви продасте більше квитків, ніж "
"планували!"

#: pretix/control/forms/orders.py:80
msgid "Overbook quota and ignore late payment"
msgstr "Перебронювання квоти та ігнорування прострочених платежів"

#: pretix/control/forms/orders.py:81
msgid ""
"If you check this box, this operation will be performed even if it leads to "
"an overbooked quota and you having sold more tickets than you planned! The "
"operation will also be performed regardless of the settings for late "
"payments."
msgstr ""
"Якщо ви поставите позначку в цьому полі, ця операція буде виконана, навіть "
"якщо це призведе до перевищення квоти, і ви продасте більше квитків, ніж "
"планували! Операцію також буде виконано незалежно від налаштувань "
"прострочених платежів."

#: pretix/control/forms/orders.py:115 pretix/control/forms/orders.py:159
msgid "Notify customer by email"
msgstr "Повідомити клієнта електронною поштою"

#: pretix/control/forms/orders.py:122
msgid "Keep a cancellation fee of"
msgstr "Утримуйте плату за скасування"

#: pretix/control/forms/orders.py:123
msgid ""
"If you keep a fee, all positions within this order will be canceled and the "
"order will be reduced to a paid cancellation fee. Payment and shipping fees "
"will be canceled as well, so include them in your cancellation fee if you "
"want to keep them. Please always enter a gross value, tax will be calculated "
"automatically."
msgstr ""
"Якщо ви збережете комісію, усі позиції в цьому замовленні будуть скасовані, "
"а вартість замовлення буде зменшена до сплаченої комісії за скасування. "
"Плата за оплату та доставку також буде скасована, тому включіть їх до "
"комісії за скасування, якщо хочете їх зберегти. Будь ласка, завжди вводьте "
"валову вартість, податок буде розраховано автоматично."

#: pretix/control/forms/orders.py:129
msgid "Generate cancellation for invoice"
msgstr "Створити скасування для рахунку-фактури"

#: pretix/control/forms/orders.py:166
msgid "Payment amount"
msgstr "Сума платежу"

#: pretix/control/forms/orders.py:170
#: pretix/plugins/banktransfer/templates/pretixplugins/banktransfer/control.html:18
#: pretix/plugins/reports/exporters.py:360
#: pretix/plugins/reports/exporters.py:422
#: pretix/plugins/reports/exporters.py:540
#: pretix/plugins/reports/exporters.py:763
msgid "Payment date"
msgstr "Дата платежу"

#: pretix/control/forms/orders.py:208
msgid "Re-calculate taxes"
msgstr "Перерахувати податки"

#: pretix/control/forms/orders.py:211
msgid "Do not re-calculate taxes"
msgstr "Не перераховуйте податки"

#: pretix/control/forms/orders.py:212
msgid ""
"Re-calculate taxes based on address and product settings, keep gross amount "
"the same."
msgstr ""
"Перерахуйте податки на основі адреси та налаштувань продукту, збережіть "
"валову суму незмінною."

#: pretix/control/forms/orders.py:213
msgid ""
"Re-calculate taxes based on address and product settings, keep net amount "
"the same."
msgstr ""
"Перерахувати податки на основі адреси та налаштувань продукту, залишити суму "
"чистого прибутку незмінною."

#: pretix/control/forms/orders.py:218
msgid "Issue a new invoice if required"
msgstr "Виставити новий рахунок-фактуру, якщо потрібно"

#: pretix/control/forms/orders.py:222
msgid ""
"If an invoice exists for this order and this operation would change its "
"contents, the old invoice will be canceled and a new invoice will be issued."
msgstr ""
"Якщо для цього замовлення існує рахунок-фактура, і ця операція змінить його "
"вміст, старий рахунок-фактура буде скасовано, а новий буде виставлено."

#: pretix/control/forms/orders.py:227
msgid "Notify user"
msgstr "Повідомити користувача"

#: pretix/control/forms/orders.py:231
msgid ""
"Send an email to the customer notifying that their order has been changed."
msgstr ""
"Надіслати клієнту електронного листа з повідомленням про зміни в його "
"замовленні."

#: pretix/control/forms/orders.py:235
msgid "Allow to overbook quotas when performing this operation"
msgstr "Дозволити перебронювання квот під час виконання цієї операції"

#: pretix/control/forms/orders.py:251
msgid "Add-on to"
msgstr "Додаток до"

#: pretix/control/forms/orders.py:256
#: pretix/control/templates/pretixcontrol/checkin/index.html:81
#: pretix/control/templates/pretixcontrol/order/change.html:118
#: pretix/control/views/vouchers.py:73
#: pretix/presale/templates/pretixpresale/event/checkout_questions.html:85
msgid "Seat"
msgstr "Сидіння"

#: pretix/control/forms/orders.py:263
msgid "Including taxes, if any. Keep empty for the product's default price"
msgstr ""
"Включно з податками, якщо такі є. Залиште поле порожнім, щоб відобразити "
"ціну товару за замовчуванням"

#: pretix/control/forms/orders.py:361 pretix/control/forms/orders.py:365
#: pretix/control/forms/orders.py:376 pretix/control/forms/orders.py:413
#: pretix/control/forms/orders.py:429 pretix/control/forms/orders.py:457
msgid "(Unchanged)"
msgstr "(Без змін)"

#: pretix/control/forms/orders.py:371 pretix/control/forms/orders.py:452
msgid "New price (gross)"
msgstr "Нова ціна (брутто)"

#: pretix/control/forms/orders.py:380
msgid "Generate a new secret"
msgstr "Згенерувати новий секрет"

#: pretix/control/forms/orders.py:384
msgid "Cancel this position"
msgstr "Скасувати цю позицію"

#: pretix/control/forms/orders.py:388
msgid "Split into new order"
msgstr "Розділити на новий порядок"

#: pretix/control/forms/orders.py:461
msgid "Remove this fee"
msgstr "Видалити цю плату"

#: pretix/control/forms/orders.py:476
msgid "Invalidate secrets"
msgstr "Визнати секрети недійсними"

#: pretix/control/forms/orders.py:477
msgid ""
"Regenerates the order and ticket secrets. You will need to re-send the link "
"to the order page to the user and the user will need to download his tickets "
"again. The old versions will be invalid."
msgstr ""
"Повторно генерує секретні коди замовлення та квитка. Вам потрібно буде "
"повторно надіслати користувачеві посилання на сторінку замовлення, і "
"користувачеві потрібно буде знову завантажити свої квитки. Старі версії "
"будуть недійсними."

#: pretix/control/forms/orders.py:510 pretix/control/forms/orders.py:727
#: pretix/control/forms/orders.py:754 pretix/control/forms/vouchers.py:228
#: pretix/plugins/sendmail/forms.py:24 pretix/plugins/sendmail/forms.py:119
msgid "Subject"
msgstr "Суб'єкт"

#: pretix/control/forms/orders.py:534
msgid "Recipient"
msgstr "Одержувач"

#: pretix/control/forms/orders.py:540 pretix/control/forms/orders.py:554
#: pretix/control/forms/orders.py:735 pretix/control/forms/orders.py:762
#: pretix/control/forms/vouchers.py:234 pretix/plugins/sendmail/forms.py:25
#: pretix/plugins/sendmail/forms.py:124
msgid "Message"
msgstr "Повідомлення"

#: pretix/control/forms/orders.py:567
msgid ""
"Cancel the order. All tickets will no longer work. This can not be reverted."
msgstr ""
"Скасувати замовлення. Усі квитки більше не працюватимуть. Цю дію не можна "
"буде повернути назад."

#: pretix/control/forms/orders.py:568
msgid ""
"Mark the order as pending and allow the user to pay the open amount with "
"another payment method."
msgstr ""
"Позначити замовлення як таке, що очікує на розгляд, і дозволити "
"користувачеві оплатити відкриту суму іншим способом оплати."

#: pretix/control/forms/orders.py:570
msgid "Do nothing and keep the order as it is."
msgstr "Нічого не робити і залишити порядок таким, яким він є."

#: pretix/control/forms/orders.py:597
msgid "The refund amount needs to be positive and less than {}."
msgstr "Сума відшкодування має бути позитивною та меншою за {}."

#: pretix/control/forms/orders.py:603
msgid "You need to specify an amount for a partial refund."
msgstr "Вам потрібно вказати суму для часткового повернення коштів."

#: pretix/control/forms/orders.py:615
msgid "Cancel all dates"
msgstr "Скасувати всі дати"

#: pretix/control/forms/orders.py:634
msgid "Automatically refund money if possible"
msgstr "Автоматичне повернення коштів, якщо це можливо"

#: pretix/control/forms/orders.py:639
msgid ""
"Create manual refund if the payment method does not support automatic refunds"
msgstr ""
"Створити повернення коштів вручну, якщо спосіб оплати не підтримує "
"автоматичне повернення коштів"

#: pretix/control/forms/orders.py:643
msgid ""
"If checked, all payments with a payment method not supporting automatic "
"refunds will be on your manual refund to-do list. Do not check if you want "
"to refund some of the orders by offsetting with different orders or issuing "
"gift cards."
msgstr ""
"Якщо позначено, усі платежі, здійснені за допомогою способу оплати, який не "
"підтримує автоматичне повернення коштів, будуть включені до вашого списку "
"справ для ручного повернення коштів. Не позначайте, якщо ви хочете повернути "
"кошти за деякі замовлення шляхом взаємозаліку з іншими замовленнями або "
"видачі подарункових карток."

#: pretix/control/forms/orders.py:648
msgid ""
"Refund order value to a gift card instead instead of the original payment "
"method"
msgstr ""
"Повернути вартість замовлення на подарункову картку замість оригінального "
"способу оплати"

#: pretix/control/forms/orders.py:654
msgid "Gift card validity"
msgstr "Термін дії подарункової картки"

#: pretix/control/forms/orders.py:673
msgid "Keep a fixed cancellation fee per ticket"
msgstr "Зберігайте фіксовану плату за скасування кожного квитка"

#: pretix/control/forms/orders.py:674
msgid "Free tickets and add-on products are not counted"
msgstr "Безкоштовні квитки та додаткові товари не враховуються"

#: pretix/control/forms/orders.py:684
msgid "Keep fees"
msgstr "Зберегти комісії"

#: pretix/control/forms/orders.py:687
msgid ""
"The selected types of fees will not be refunded but instead added to the "
"cancellation fee. Fees are never refunded in when an order in an event "
"series is only partially canceled since it consists of tickets for multiple "
"dates."
msgstr ""
"Вибрані типи зборів не будуть повернені, а натомість будуть додані до збору "
"за скасування. Збори ніколи не повертаються, якщо замовлення в серії подій "
"скасовано лише частково, оскільки воно складається з квитків на кілька дат."

#: pretix/control/forms/orders.py:693
msgid "Send information via email"
msgstr "Надіслати інформацію електронною поштою"

#: pretix/control/forms/orders.py:699
msgid "Send information to waiting list"
msgstr "Надіслати інформацію до списку очікування"

#: pretix/control/forms/orders.py:730 pretix/control/forms/orders.py:756
#, python-brace-format
msgid "Canceled: {event}"
msgstr "Скасовано: {event}"

#: pretix/control/forms/orders.py:741
#, python-brace-format
msgid ""
"Hello,\n"
"\n"
"with this email, we regret to inform you that {event} has been canceled.\n"
"\n"
"We will refund you {refund_amount} to your original payment method.\n"
"\n"
"You can view the current state of your order here:\n"
"\n"
"{url}\n"
"\n"
"Best regards,\n"
"\n"
"Your {event} team"
msgstr ""
"Вітаємо,\n"
"\n"
"Цим листом ми з жалем повідомляємо Вам, що подію {event} скасовано.\n"
"\n"
"Ми повернемо Вам {refund_amount} на Ваш початковий спосіб оплати.\n"
"\n"
"Ви можете переглянути поточний стан Вашого замовлення тут:\n"
"\n"
"{url}\n"
"\n"
"З найкращими побажаннями,\n"
"\n"
"Ваша команда {event}"

#: pretix/control/forms/orders.py:768
#, python-brace-format
msgid ""
"Hello,\n"
"\n"
"with this email, we regret to inform you that {event} has been canceled.\n"
"\n"
"You will therefore not receive a ticket from the waiting list.\n"
"\n"
"Best regards,\n"
"\n"
"Your {event} team"
msgstr ""
"Вітаємо,\n"
"\n"
"Цим листом ми з жалем повідомляємо Вам, що подію {event} скасовано.\n"
"\n"
"Тому Ви не отримаєте квиток зі списку очікування.\n"
"\n"
"З найкращими побажаннями,\n"
"\n"
"Ваша команда {event}"

#: pretix/control/forms/orders.py:800 pretix/plugins/sendmail/forms.py:82
msgctxt "subevent"
msgid "Please either select a specific date or a date range, not both."
msgstr ""
"Будь ласка, виберіть або конкретну дату, або діапазон дат, а не обидва "
"варіанти одночасно."

#: pretix/control/forms/orders.py:802
msgctxt "subevent"
msgid "Please either select all dates or a date range, not both."
msgstr ""
"Будь ласка, виберіть або всі дати, або діапазон дат, а не обидва варіанти "
"одночасно."

#: pretix/control/forms/orders.py:804 pretix/plugins/sendmail/forms.py:84
msgctxt "subevent"
msgid "If you set a date range, please set both a start and an end."
msgstr ""
"Якщо ви встановлюєте діапазон дат, будь ласка, вкажіть як початковий, так і "
"кінцевий періоди."

#: pretix/control/forms/orders.py:806
msgid "Please confirm that you want to cancel ALL dates in this event series."
msgstr ""
"Будь ласка, підтвердіть, що ви хочете скасувати ВСІ дати в цій серії подій."

#: pretix/control/forms/organizer_forms/device_form.py:22
msgid ""
"Your device will not have access to anything, please select some events."
msgstr ""
"Ваш пристрій не матиме доступу ні до чого, будь ласка, виберіть кілька подій."

#: pretix/control/forms/organizer_forms/gift_card_create_form.py:15
msgid "Gift card value"
msgstr "Вартість подарункової картки"

#: pretix/control/forms/organizer_forms/organizer_form.py:17
msgid "This slug is already in use. Please choose a different one."
msgstr "Цей слуг вже використовується. Будь ласка, виберіть інший."

